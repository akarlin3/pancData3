# pancData3 Docker Compose environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: path to patient DWI data directory on the host
DATA_DIR=/path/to/patient_dwi_data

# Optional: path to pipeline output directory (default: ./output)
OUTPUT_DIR=./output

# Optional: path to config.json on the host (default: ./config.json)
CONFIG_FILE=./config.json

# Optional: API keys for vision-based graph analysis
# Get a Gemini key at https://aistudio.google.com/
GEMINI_API_KEY=

# Get an Anthropic key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
